generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// VITAE — Database Schema
// ============================================

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  avatarUrl    String?
  supabaseId   String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  resumes      Resume[]
  coverLetters CoverLetter[]
  aiUsageLogs  AIUsageLog[]
}

model Resume {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String          @default("Untitled Resume")
  templateId String
  template   Template        @relation(fields: [templateId], references: [id])
  content    Json
  atsScore   Int?
  tone       ResumeTone      @default(CORPORATE)
  isPublic   Boolean         @default(false)
  publicSlug String?         @unique
  version    Int             @default(1)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  exports    Export[]
  versions   ResumeVersion[]

  @@index([userId])
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  content   Json
  version   Int
  createdAt DateTime @default(now())

  @@index([resumeId])
}

model Template {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  category   TemplateCategory
  previewUrl String
  styles     Json
  structure  Json
  createdAt  DateTime         @default(now())
  resumes    Resume[]
}

model CoverLetter {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId  String?
  title     String
  content   String     @db.Text
  jobTitle  String?
  company   String?
  tone      ResumeTone @default(CORPORATE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model Export {
  id        String       @id @default(cuid())
  resumeId  String
  resume    Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  format    ExportFormat
  fileUrl   String?
  createdAt DateTime     @default(now())

  @@index([resumeId])
}

model AIUsageLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AIAction
  tokens    Int
  model     String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id         String            @id @default(cuid())
  supabaseId String
  title      String
  body       String?
  link       String?
  type       NotificationType  @default(SYSTEM)
  readAt     DateTime?
  createdAt  DateTime          @default(now())

  @@index([supabaseId])
  @@index([createdAt])
}

model WorkspaceSettings {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  notifications Json
  exports       Json
  editor        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supabaseId])
}

enum ResumeTone {
  CORPORATE
  STARTUP
  CREATIVE
  EXECUTIVE
  MINIMALIST
}

enum TemplateCategory {
  CLASSIC_HARVARD
  CONSULTING_ELITE
  INVESTMENT_BANKING
  MODERN_EXECUTIVE
  TECH_PROFESSIONAL
}

enum ExportFormat {
  PDF
  DOCX
  TXT
}

enum AIAction {
  GENERATE_RESUME
  REWRITE_BULLET
  SCORE_RESUME
  GENERATE_COVER_LETTER
  JOB_MATCH
  CHAT_ASSIST
}

enum NotificationType {
  SYSTEM
  RESUME_IMPORT
  RESUME_EXPORT
  RESUME_UPDATE
}
